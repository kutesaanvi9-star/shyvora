<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shyvora | Timeless Jewellery</title>
  <meta
    name="description"
    content="Shyvora crafts timeless jewellery designed for elegance, confidence, and everyday luxury."
  />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="hero">
    <nav class="navbar container">
      <div class="logo">SHYVORA</div>
      <ul class="nav-links">
        <li><a href="#collections">Collections</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#featured">Featured</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <button class="menu-toggle" aria-label="Open menu">☰</button>
    </nav>

    <div class="hero-content container">
      <p class="eyebrow">Fine Jewellery • Modern Grace</p>
      <h1>Where elegance becomes everyday.</h1>
      <p class="hero-text">
        Discover handcrafted jewellery that blends timeless beauty with modern style.
      </p>
      <div class="hero-buttons">
        <a href="#collections" class="btn btn-primary">Explore Collection</a>
        <a href="#contact" class="btn btn-secondary">Shop Enquiry</a>
      </div>
    </div>
  </header>

  <main>
    <section id="collections" class="section container">
      <div class="section-heading">
        <p class="section-tag">Collections</p>
        <h2>Signature pieces by Shyvora</h2>
      </div>

      <div class="card-grid">
        <article class="card">
          <div class="card-image">Rings</div>
          <h3>Radiant Rings</h3>
          <p>Minimal and statement rings designed to shine at every moment.</p>
        </article>

        <article class="card">
          <div class="card-image">Necklaces</div>
          <h3>Luxe Necklaces</h3>
          <p>Layered, delicate, and bold styles for refined everyday elegance.</p>
        </article>

        <article class="card">
          <div class="card-image">Earrings</div>
          <h3>Classic Earrings</h3>
          <p>From sparkling studs to elevated drops, crafted with timeless appeal.</p>
        </article>
      </div>
    </section>

    <section id="about" class="section dark-section">
      <div class="container about-grid">
        <div>
          <p class="section-tag">About Shyvora</p>
          <h2>Crafted to tell your story.</h2>
          <p>
            Shyvora is a jewellery brand rooted in elegance, femininity, and confidence.
            Every piece is designed to celebrate modern beauty while honoring timeless craftsmanship.
          </p>
        </div>
        <div class="about-box">
          <h3>Our Promise</h3>
          <p>Premium design, graceful detail, and a luxurious experience in every collection.</p>
        </div>
      </div>
    </section>

    <section id="featured" class="section container">
      <div class="section-heading">
        <p class="section-tag">Featured</p>
        <h2>Bestsellers</h2>
      </div>

      <div class="featured-grid">
        <div class="featured-item">
          <span class="price">$89</span>
          <h3>Moonlit Gold Ring</h3>
          <p>Elegant gold-tone ring with a sleek, polished finish.</p>
        </div>
        <div class="featured-item">
          <span class="price">$129</span>
          <h3>Celeste Pendant</h3>
          <p>A delicate necklace designed to elevate every outfit.</p>
        </div>
        <div class="featured-item">
          <span class="price">$99</span>
          <h3>Velora Studs</h3>
          <p>Classic sparkling studs that add subtle brilliance.</p>
        </div>
      </div>
    </section>

    <section id="contact" class="section contact-section">
      <div class="container contact-grid">
        <div>
          <p class="section-tag">Contact</p>
          <h2>Connect with Shyvora</h2>
          <p>Email us for orders, custom pieces, and collaborations.</p>
        </div>

        <form class="contact-form">
          <input type="text" placeholder="Your name" required />
          <input type="email" placeholder="Your email" required />
          <textarea rows="5" placeholder="Your message" required></textarea>
          <button type="submit" class="btn btn-primary">Send Enquiry</button>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-content">
      <p>© 2026 Shyvora. All rights reserved.</p>
      <p>Instagram | Pinterest | Email</p>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
