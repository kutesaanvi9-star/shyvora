<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shyvora | Luxury Jewellery</title>
  <link rel="preconnect" href="[fonts.googleapis.com](https://fonts.googleapis.com)" />
  <link rel="preconnect" href="[fonts.gstatic.com](https://fonts.gstatic.com)" crossorigin />
  <link
    href="[fonts.googleapis.com](https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap)"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="hero">
    <nav class="navbar container">
      <div class="logo">SHYVORA</div>
      <ul class="nav-links">
        <li><a href="#collections">Collections</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#featured">Featured</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <button class="menu-toggle" aria-label="Open menu">☰</button>
    </nav>

    <div class="hero-content container">
      <p class="eyebrow">Luxury in Every Detail</p>
      <h1>Jewellery designed to be remembered.</h1>
      <p class="hero-text">
        Discover refined pieces by Shyvora that blend timeless craftsmanship with modern femininity.
      </p>
      <div class="hero-buttons">
        <a href="#collections" class="btn btn-primary">View Collection</a>
        <a href="#contact" class="btn btn-secondary">Enquire Now</a>
      </div>
    </div>
  </header>

  <main>
    <section id="collections" class="section container">
      <div class="section-heading">
        <p class="section-tag">Our Collection</p>
        <h2>Made to shine with you</h2>
      </div>

      <div class="card-grid">
        <article class="card">
          <div class="card-image">Signature Rings</div>
          <h3>Rings</h3>
          <p>Elegant silhouettes crafted for both statement and everyday wear.</p>
        </article>
        <article class="card">
          <div class="card-image">Modern Chains</div>
          <h3>Necklaces</h3>
          <p>Graceful necklaces designed to layer beautifully and wear effortlessly.</p>
        </article>
        <article class="card">
          <div class="card-image">Refined Sparkle</div>
          <h3>Earrings</h3>
          <p>Classic and contemporary earrings with a polished luxury finish.</p>
        </article>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-content">
      <p>© 2026 Shyvora. All rights reserved.</p>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
